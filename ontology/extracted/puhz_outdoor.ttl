@prefix lab:  <http://lab.example/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Source: spec_PUHZ-HW.pdf (Mitsubishi Ecodan Monobloc Product Information,
#         document ID 788) and BH79D532H03_PUHZ-HW.pdf (installation manual).
# These are the OUTDOOR units that pair with EHST20/EHPT20 cylinder units —
# they hold the heating capacity / COP / refrigerant data missing from
# the cylinder manuals.
#
# Test conditions for nominalCOP and nominalPowerKw: A-3/W35
# (outdoor air -3°C dry bulb, water flow 35°C).

# ─── PUHZ-W50VHA2 — 5 kW single phase ──────────────────────────────────
lab:puhz_w50 a lab:AirToWaterHP ;
    rdfs:label         "Mitsubishi EcoDan PUHZ-W50VHA2 (outdoor, 5 kW)" ;
    lab:manufacturer   "Mitsubishi Electric" ;
    lab:modelSeries    "PUHZ-W" ;
    lab:modelVariant   "PUHZ-W50VHA2" ;
    lab:modelVariant   "PUHZ-W50VHA2-BS" ;
    lab:nominalPowerKw "4.8"^^xsd:float ;
    lab:nominalCOP     "2.95"^^xsd:float ;
    lab:refrigerant    "R410A" ;
    lab:weightKg       "64.0"^^xsd:float ;
    lab:powerSupplyV   "230"^^xsd:integer ;
    lab:hasOperatingMode lab:heating_mode , lab:dhw_mode , lab:standby_mode ;
    lab:hasComponent   lab:puhz_w50_compressor ,
                       lab:puhz_w50_evaporator ,
                       lab:puhz_w50_expansion_valve .

lab:puhz_w50_compressor      a lab:Compressor ; rdfs:label "Compressor (PUHZ-W50)" .
lab:puhz_w50_evaporator      a lab:Evaporator ; rdfs:label "Air-source evaporator (PUHZ-W50)" .
lab:puhz_w50_expansion_valve a lab:Component  ; rdfs:label "Expansion valve (PUHZ-W50)" .

