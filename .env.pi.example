# Конфігурація edge-analyzer на Raspberry Pi.
# Скопіюй у .env.pi і заповни IP сервера.
#
#   cp .env.pi.example .env.pi
#   nano .env.pi
#
# Потім:
#   docker compose -f docker-compose.pi.yml --env-file .env.pi up -d

# ── Ідентифікатор пристрою (з онтології equipment.ttl) ──
DEVICE_ID=ecodan_01

# ── Адреса серверного MQTT-брокера ──
# Заміни 192.168.1.10 на справжній IP комп'ютера, де запущено основний compose.
# Перевірити з Pi:  ping 192.168.1.10
MQTT_BROKER=192.168.1.10
MQTT_PORT=1883

# ── REST API сервера ──
# 5002 — ontology_api (SPARQL → HTTP)
# 5003 — alerts_server (приймає тривоги, віддає dashboard)
ONTOLOGY_API=http://192.168.1.10:5002
ALERTS_API=http://192.168.1.10:5003

# ── Як часто нагадувати про активну тривогу (с) ──
REMIND_INTERVAL_SEC=300

# ── Локальний порт Web-панелі на самій Pi (необов'язково) ──
ANALYZER_WEB_PORT=5001
