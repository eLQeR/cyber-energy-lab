@prefix lab:  <http://lab.example/ontology#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://lab.example/ontology> a owl:Ontology ;
    rdfs:label "Cyber-Energy Lab Equipment Ontology" .

# ─── Класи ─────────────────────────────────────────────────────────────
lab:Equipment        a owl:Class ; rdfs:label "Обладнання" .
lab:HeatPump         a owl:Class ; rdfs:subClassOf lab:Equipment ;
                     rdfs:label "Тепловий насос" .
lab:AirToWaterHP     a owl:Class ; rdfs:subClassOf lab:HeatPump ;
                     rdfs:label "Повітря-вода" .
lab:Component        a owl:Class ; rdfs:label "Компонент" .
lab:Compressor       a owl:Class ; rdfs:subClassOf lab:Component .
lab:Evaporator       a owl:Class ; rdfs:subClassOf lab:Component .
lab:Condenser        a owl:Class ; rdfs:subClassOf lab:Component .
lab:OperatingMode    a owl:Class ; rdfs:label "Режим роботи" .
lab:TechnicalSpec    a owl:Class ; rdfs:label "Технічна характеристика" .

# ─── Властивості ───────────────────────────────────────────────────────
lab:hasComponent     a owl:ObjectProperty ;
                     rdfs:domain lab:Equipment ;
                     rdfs:range  lab:Component .
lab:hasOperatingMode a owl:ObjectProperty ;
                     rdfs:domain lab:Equipment ;
                     rdfs:range  lab:OperatingMode .
lab:hasSpec          a owl:ObjectProperty ;
                     rdfs:domain lab:Equipment ;
                     rdfs:range  lab:TechnicalSpec .

lab:nominalPowerKw   a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:maxPowerKw       a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:maxFlowTempC     a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:minFlowTempC     a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:minCOP           a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:nominalCOP       a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:tankVolumeL      a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:weightKg         a owl:DatatypeProperty ; rdfs:range xsd:float .
lab:powerSupplyV     a owl:DatatypeProperty ; rdfs:range xsd:integer .
lab:refrigerant      a owl:DatatypeProperty ; rdfs:range xsd:string .
lab:manufacturer     a owl:DatatypeProperty ; rdfs:range xsd:string .
lab:model            a owl:DatatypeProperty ; rdfs:range xsd:string .
lab:modelSeries      a owl:DatatypeProperty ; rdfs:range xsd:string .
lab:modelVariant     a owl:DatatypeProperty ; rdfs:range xsd:string .

# ─── Екземпляри ────────────────────────────────────────────────────────
lab:heating_mode  a lab:OperatingMode ; rdfs:label "Обігрів" .
lab:cooling_mode  a lab:OperatingMode ; rdfs:label "Охолодження" .
lab:dhw_mode      a lab:OperatingMode ; rdfs:label "ГВП" .
lab:standby_mode  a lab:OperatingMode ; rdfs:label "Очікування" .

lab:ecodan_01 a lab:AirToWaterHP ;
    rdfs:label         "Mitsubishi EcoDan (лабораторний)" ;
    lab:manufacturer   "Mitsubishi Electric" ;
    lab:model          "EHST20D-VM6D" ;
    lab:nominalPowerKw "2.5"^^xsd:float ;
    lab:maxPowerKw     "4.0"^^xsd:float ;
    lab:maxFlowTempC   "60.0"^^xsd:float ;
    lab:minFlowTempC   "20.0"^^xsd:float ;
    lab:minCOP         "2.8"^^xsd:float ;
    lab:hasComponent   lab:ecodan_01_compressor ,
                       lab:ecodan_01_evaporator ,
                       lab:ecodan_01_condenser ;
    lab:hasOperatingMode lab:heating_mode , lab:dhw_mode , lab:standby_mode .

lab:ecodan_01_compressor a lab:Compressor ; rdfs:label "Компресор EcoDan" .
lab:ecodan_01_evaporator a lab:Evaporator ; rdfs:label "Випарник EcoDan" .
lab:ecodan_01_condenser  a lab:Condenser  ; rdfs:label "Конденсатор EcoDan" .
@prefix lab:  <http://lab.example/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Source: Mitsubishi installation manual BH79D188H02.pdf (revision A series)
# Covers cylinder units EHST20C-*M*HA / *M*A / VM6SA and EHPT20X variants.

lab:ehst20_revA a lab:AirToWaterHP ;
    rdfs:label         "Mitsubishi EcoDan EHST20/EHPT20 (rev. A)" ;
    lab:manufacturer   "Mitsubishi Electric" ;
    lab:modelSeries    "EHST20" ;
    lab:modelSeries    "EHPT20" ;
    lab:modelVariant   "EHST20C-VM6HA" ;
    lab:modelVariant   "EHST20C-YM9HA" ;
    lab:modelVariant   "EHST20C-VM6A" ;
    lab:modelVariant   "EHST20C-YM9A" ;
    lab:modelVariant   "EHST20C-VM6SA" ;
    lab:modelVariant   "EHPT20X-VM2HA" ;
    lab:modelVariant   "EHPT20X-VM6HA" ;
    lab:modelVariant   "EHPT20X-YM9HA" ;
    lab:modelVariant   "EHPT20X-VM6A" ;
    lab:modelVariant   "EHPT20X-YM9A" ;
    lab:tankVolumeL    "200.0"^^xsd:float ;
    lab:maxFlowTempC   "60.0"^^xsd:float ;
    lab:minFlowTempC   "25.0"^^xsd:float ;
    lab:refrigerant    "R410A" ;
    lab:powerSupplyV   "230"^^xsd:integer ;
    lab:hasOperatingMode lab:heating_mode , lab:dhw_mode , lab:standby_mode ;
    lab:hasComponent   lab:ehst20_revA_compressor ,
                       lab:ehst20_revA_evaporator ,
                       lab:ehst20_revA_condenser ,
                       lab:ehst20_revA_plate_hex ,
                       lab:ehst20_revA_booster_heater ,
                       lab:ehst20_revA_immersion_heater .

lab:ehst20_revA_compressor       a lab:Compressor   ; rdfs:label "Compressor (outdoor unit)" .
lab:ehst20_revA_evaporator       a lab:Evaporator   ; rdfs:label "Evaporator (outdoor air heat exchanger)" .
lab:ehst20_revA_condenser        a lab:Condenser    ; rdfs:label "Condenser" .
lab:ehst20_revA_plate_hex        a lab:Component    ; rdfs:label "Plate heat exchanger" .
lab:ehst20_revA_booster_heater   a lab:Component    ; rdfs:label "Booster heater (2 kW + 4 kW or 3 kW + 6 kW)" .
lab:ehst20_revA_immersion_heater a lab:Component    ; rdfs:label "Immersion heater (3 kW)" .
@prefix lab:  <http://lab.example/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Source: Mitsubishi installation manual BH79D290H03.pdf (revision B series)
# Covers cylinder units EHST20C-*M*HB / *M*B / VM6SB and EHPT20X variants.

lab:ehst20_revB a lab:AirToWaterHP ;
    rdfs:label         "Mitsubishi EcoDan EHST20/EHPT20 (rev. B)" ;
    lab:manufacturer   "Mitsubishi Electric" ;
    lab:modelSeries    "EHST20" ;
    lab:modelSeries    "EHPT20" ;
    lab:modelVariant   "EHST20C-VM6HB" ;
    lab:modelVariant   "EHST20C-YM9HB" ;
    lab:modelVariant   "EHST20C-TM9HB" ;
    lab:modelVariant   "EHST20C-VM2B" ;
    lab:modelVariant   "EHST20C-VM6B" ;
    lab:modelVariant   "EHST20C-YM9B" ;
    lab:modelVariant   "EHST20C-VM6SB" ;
    lab:modelVariant   "EHPT20X-VM2HB" ;
    lab:modelVariant   "EHPT20X-VM6HB" ;
    lab:modelVariant   "EHPT20X-YM9HB" ;
    lab:modelVariant   "EHPT20X-TM9HB" ;
    lab:modelVariant   "EHPT20X-VM2B" ;
    lab:modelVariant   "EHPT20X-VM6B" ;
    lab:modelVariant   "EHPT20X-YM9B" ;
    lab:tankVolumeL    "200.0"^^xsd:float ;
    lab:maxFlowTempC   "60.0"^^xsd:float ;
    lab:minFlowTempC   "25.0"^^xsd:float ;
    lab:refrigerant    "R410A" ;
    lab:powerSupplyV   "230"^^xsd:integer ;
    lab:hasOperatingMode lab:heating_mode , lab:dhw_mode , lab:standby_mode ;
    lab:hasComponent   lab:ehst20_revB_compressor ,
                       lab:ehst20_revB_evaporator ,
                       lab:ehst20_revB_condenser ,
                       lab:ehst20_revB_plate_hex ,
                       lab:ehst20_revB_booster_heater ,
                       lab:ehst20_revB_immersion_heater .

lab:ehst20_revB_compressor       a lab:Compressor   ; rdfs:label "Compressor (outdoor unit)" .
lab:ehst20_revB_evaporator       a lab:Evaporator   ; rdfs:label "Evaporator (outdoor air heat exchanger)" .
lab:ehst20_revB_condenser        a lab:Condenser    ; rdfs:label "Condenser" .
lab:ehst20_revB_plate_hex        a lab:Component    ; rdfs:label "Plate heat exchanger" .
lab:ehst20_revB_booster_heater   a lab:Component    ; rdfs:label "Booster heater (2 kW + 4 kW or 3 kW + 6 kW)" .
lab:ehst20_revB_immersion_heater a lab:Component    ; rdfs:label "Immersion heater (3 kW)" .
@prefix lab:  <http://lab.example/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Source: spec_PUHZ-HW.pdf (Mitsubishi Ecodan Monobloc Product Information,
#         document ID 788) and BH79D532H03_PUHZ-HW.pdf (installation manual).
# These are the OUTDOOR units that pair with EHST20/EHPT20 cylinder units —
# they hold the heating capacity / COP / refrigerant data missing from
# the cylinder manuals.
#
# Test conditions for nominalCOP and nominalPowerKw: A-3/W35
# (outdoor air -3°C dry bulb, water flow 35°C).

# ─── PUHZ-W50VHA2 — 5 kW single phase ──────────────────────────────────
lab:puhz_w50 a lab:AirToWaterHP ;
    rdfs:label         "Mitsubishi EcoDan PUHZ-W50VHA2 (outdoor, 5 kW)" ;
    lab:manufacturer   "Mitsubishi Electric" ;
    lab:modelSeries    "PUHZ-W" ;
    lab:modelVariant   "PUHZ-W50VHA2" ;
    lab:modelVariant   "PUHZ-W50VHA2-BS" ;
    lab:nominalPowerKw "4.8"^^xsd:float ;
    lab:nominalCOP     "2.95"^^xsd:float ;
    lab:refrigerant    "R410A" ;
    lab:weightKg       "64.0"^^xsd:float ;
    lab:powerSupplyV   "230"^^xsd:integer ;
    lab:hasOperatingMode lab:heating_mode , lab:dhw_mode , lab:standby_mode ;
    lab:hasComponent   lab:puhz_w50_compressor ,
                       lab:puhz_w50_evaporator ,
                       lab:puhz_w50_expansion_valve .

lab:puhz_w50_compressor      a lab:Compressor ; rdfs:label "Compressor (PUHZ-W50)" .
lab:puhz_w50_evaporator      a lab:Evaporator ; rdfs:label "Air-source evaporator (PUHZ-W50)" .
lab:puhz_w50_expansion_valve a lab:Component  ; rdfs:label "Expansion valve (PUHZ-W50)" .

# ─── PUHZ-W85VHA2 — 8.5 kW single phase ────────────────────────────────
