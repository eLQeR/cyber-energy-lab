    lab:nominalCOP     "2.80"^^xsd:float ;
    lab:refrigerant    "R410A" ;
    lab:weightKg       "77.0"^^xsd:float ;
    lab:powerSupplyV   "230"^^xsd:integer ;
    lab:hasOperatingMode lab:heating_mode , lab:dhw_mode , lab:standby_mode ;
    lab:hasComponent   lab:puhz_w85_compressor ,
                       lab:puhz_w85_evaporator ,
                       lab:puhz_w85_expansion_valve .

lab:puhz_w85_compressor      a lab:Compressor ; rdfs:label "Compressor (PUHZ-W85)" .
lab:puhz_w85_evaporator      a lab:Evaporator ; rdfs:label "Air-source evaporator (PUHZ-W85)" .
lab:puhz_w85_expansion_valve a lab:Component  ; rdfs:label "Expansion valve (PUHZ-W85)" .

